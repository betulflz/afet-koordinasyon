@model AfetYonetim.Models.ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-danger">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-exclamation-triangle mr-2"></i>Bir hata oluştu
                </h3>
            </div>
            <div class="card-body text-center">
                <h1 class="display-4 text-danger">
                    <i class="fas fa-bug"></i>
                </h1>
                <p class="lead">İsteğiniz işlenirken bir hata meydana geldi.</p>
                @if (Model?.ShowRequestId ?? false)
                {
                    <p class="text-muted">
                        <strong>İstek ID:</strong> <code>@Model?.RequestId</code>
                    </p>
                }
                <a href="~/" class="btn btn-primary mt-3">
                    <i class="fas fa-home mr-2"></i>Ana Sayfaya Dön
                </a>
            </div>
        </div>
    </div>
</div>