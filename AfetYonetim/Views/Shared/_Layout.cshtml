@inject Microsoft.AspNetCore.Identity.SignInManager<AfetYonetim.Models.Entities.ApplicationUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<AfetYonetim.Models.Entities.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - Afet Yönetim Sistemi</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
    <link rel="stylesheet" href="~/css/site.css">

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="hold-transition sidebar-mini layout-fixed">
<div class="wrapper">

    <nav class="main-header navbar navbar-expand navbar-white navbar-light">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-widget="pushmenu" href="#" role="button">
                    <i class="fas fa-bars"></i>
                </a>
            </li>
        </ul>

        <ul class="navbar-nav ml-auto">
            @if (SignInManager.IsSignedIn(User))
            {
                @* FAZ 4: Admin Bildirim Çanı Bileşeni Buraya Eklendi *@
                @await Html.PartialAsync("_NavbarNotifications")

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button"
                       data-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-user-circle mr-1"></i>
                        @{
                            var currentUser = await UserManager.GetUserAsync(User);
                            @(currentUser?.FullName ?? "Kullanıcı")
                        }
                    </a>
                    <div class="dropdown-menu dropdown-menu-right shadow-sm" aria-labelledby="userDropdown">
                        <span class="dropdown-item-text text-muted small font-weight-bold">
                            @if (User.IsInRole("Admin")) { <text><i class="fas fa-user-shield mr-1"></i>Admin</text> }
                            else if (User.IsInRole("Afetzede")) { <text><i class="fas fa-user mr-1"></i>Afetzede</text> }
                            else if (User.IsInRole("Gonullu")) { <text><i class="fas fa-hands-helping mr-1"></i>Gönüllü</text> }
                        </span>
                        <div class="dropdown-divider"></div>
                        @{
                            var navProfileUrl = User.IsInRole("Admin") ? "/Admin/Profile" :
                                                (User.IsInRole("Afetzede") ? "/Afetzede/Profile" :
                                                (User.IsInRole("Gonullu") ? "/Gonullu/Profile" : "/"));
                        }
                        <a class="dropdown-item" href="@navProfileUrl">
                            <i class="fas fa-cog mr-2"></i> Profil
                        </a>
                        <div class="dropdown-divider"></div>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit" class="dropdown-item text-danger">
                                <i class="fas fa-sign-out-alt mr-2"></i> Çıkış Yap
                            </button>
                        </form>
                    </div>
                </li>
            }
        </ul>
    </nav>
    <aside class="main-sidebar sidebar-dark-primary elevation-4">
        <a href="~/" class="brand-link">
            <i class="fas fa-hands-helping brand-image ml-3" style="font-size: 1.5rem; color: #e94560;"></i>
            <span class="brand-text font-weight-light font-weight-bold">Afet Yönetim</span>
        </a>

        <div class="sidebar">
            <nav class="mt-2">
                @await Html.PartialAsync("_Sidebar")
            </nav>
        </div>
    </aside>

    <div class="content-wrapper">
        <div class="content-header">
            <div class="container-fluid">
                <div class="row mb-2">
                    <div class="col-sm-6">
                        <h1 class="m-0 font-weight-bold text-dark">@ViewData["Title"]</h1>
                    </div>
                </div>
            </div>
        </div>

        <section class="content">
            <div class="container-fluid">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        <i class="fas fa-check-circle mr-2"></i>@TempData["Success"]
                        <button type="button" class="close" data-dismiss="alert" aria-label="Kapat">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        <i class="fas fa-exclamation-circle mr-2"></i>@TempData["Error"]
                        <button type="button" class="close" data-dismiss="alert" aria-label="Kapat">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                }

                @RenderBody()
            </div>
        </section>
    </div>

    <footer class="main-footer">
        <strong>&copy; 2026 Afet Yönetim Sistemi.</strong> Tüm hakları saklıdır.
        <div class="float-right d-none d-sm-inline-block">
            <b>Muğla Sıtkı Koçman Üniversitesi</b> — Web Programlama
        </div>
    </footer>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
<script src="~/js/site.js"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>