@model PublicLandingViewModel
@using System.Text.Json
@inject Microsoft.AspNetCore.Identity.SignInManager<AfetYonetim.Models.Entities.ApplicationUser> SignInManager
@inject Microsoft.AspNetCore.Identity.UserManager<AfetYonetim.Models.Entities.ApplicationUser> UserManager

@{
    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    string greetingHtml = "";
    string greetingLink = "";
    string greetingLinkText = "";

    if (SignInManager.IsSignedIn(User))
    {
        var u = await UserManager.GetUserAsync(User);
        var name = u?.Name ?? "Kullanıcı";
        greetingHtml = $"Hoş geldin, {name}!";
        if (User.IsInRole("Admin")) { greetingLink = "/Admin/Dashboard"; greetingLinkText = "Dashboard'a Git"; }
        else if (User.IsInRole("Afetzede")) { greetingLink = "/Afetzede/HelpRequest/Create"; greetingLinkText = "Yeni Talep Oluştur"; }
        else if (User.IsInRole("Gonullu")) { greetingLink = "/Gonullu/Assignment"; greetingLinkText = "Görevlerime Git"; }
    }
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <style>
        .lp-hero {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            color: #fff; padding: 60px 30px; text-align: center; position: relative; overflow: hidden; border-radius: 8px; margin-bottom: 24px;
        }
        .lp-hero::before {
            content: ""; position: absolute; inset: 0;
            background: radial-gradient(circle at 20% 30%, rgba(233,69,96,.15) 0%, transparent 40%), radial-gradient(circle at 80% 70%, rgba(0,123,255,.12) 0%, transparent 40%);
        }
        .lp-hero h1 { font-size: 42px; font-weight: 800; margin-bottom: 14px; position: relative; }
        .lp-hero h1 .fas { color: #e94560; }
        .lp-hero p { font-size: 17px; opacity: .85; max-width: 640px; margin: 0 auto 28px; position: relative; }
        
        .lp-stats { display: grid; grid-template-columns: repeat(4, 1fr); background: #fff; border-radius: 8px; box-shadow: 0 1px 3px rgba(0,0,0,.06); margin-bottom: 24px; overflow: hidden; }
        .lp-stat { padding: 28px 16px; text-align: center; border-right: 1px solid #f0f0f0; }
        .lp-stat:last-child { border-right: none; }
        .lp-stat-ico { width: 54px; height: 54px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 22px; color: #fff; margin-bottom: 10px; }
        .lp-stat-num { font-size: 34px; font-weight: 800; line-height: 1; }
        .lp-stat-lbl { font-size: 12px; color: #666; margin-top: 6px; text-transform: uppercase; letter-spacing: .5px; }

        .lp-section-title { font-size: 22px; font-weight: 700; color: #1a1a2e; margin: 0 0 6px; }
        .lp-section-title .fas { color: #e94560; margin-right: 8px; }
        #lpMap { height: 320px; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,.08); position: relative; z-index: 1; }

        .lp-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; padding: 32px 0; }
        .lp-step { text-align: center; padding: 30px 20px 24px; border-radius: 8px; background: #f8f9fa; position: relative; }
        .lp-step .badge-num { position: absolute; top: -14px; left: 50%; transform: translateX(-50%); width: 30px; height: 30px; background: #e94560; color: #fff; border-radius: 50%; font-weight: 700; display: flex; align-items: center; justify-content: center; }
        
        .lp-ann-card { background: #fff; border-left: 4px solid #ffc107; padding: 14px 18px; border-radius: 4px; margin-bottom: 10px; box-shadow: 0 1px 3px rgba(0,0,0,.05); }
        .lp-ann-card.urgent { border-left-color: #dc3545; }
        .lp-urgent-tag { background: #dc3545; color: #fff; font-size: 10px; padding: 2px 7px; border-radius: 3px; margin-right: 6px; font-weight: 700; }
    </style>
}

<div class="lp-hero">
    <h1><i class="fas fa-hands-helping"></i> Afet Yönetim Sistemi</h1>
    <p>Deprem ve afet anlarında afetzede, gönüllü ve koordinatörler arasında köprü kuran merkezi dijital platform. İhtiyaçlar zamanında ulaşır, kaynaklar verimli dağıtılır.</p>

    @if (SignInManager.IsSignedIn(User))
    {
        <div class="btns">
            <span class="text-light mr-3" style="font-size:18px"><i class="fas fa-user mr-1"></i>@greetingHtml</span>
            <a href="@greetingLink" class="btn btn-light px-4 font-weight-bold"><i class="fas fa-arrow-right mr-2"></i>@greetingLinkText</a>
        </div>
    }
    else
    {
        <div class="btns">
            <a href="/Account/Login" class="btn btn-light px-4 font-weight-bold mr-2"><i class="fas fa-sign-in-alt mr-2"></i>Giriş Yap</a>
            <a href="/Account/Register" class="btn btn-outline-light px-4 font-weight-bold"><i class="fas fa-user-plus mr-2"></i>Hemen Kayıt Ol</a>
        </div>
    }
</div>

<div class="lp-stats">
    <div class="lp-stat">
        <div class="lp-stat-ico" style="background:#17a2b8"><i class="fas fa-hand-holding-heart"></i></div>
        <div class="lp-stat-num" style="color:#17a2b8">@Model.TotalRequests</div>
        <div class="lp-stat-lbl">Toplam Talep</div>
    </div>
    <div class="lp-stat">
        <div class="lp-stat-ico" style="background:#28a745"><i class="fas fa-check-circle"></i></div>
        <div class="lp-stat-num" style="color:#28a745">@Model.CompletedRequests</div>
        <div class="lp-stat-lbl">Teslim Edildi</div>
    </div>
    <div class="lp-stat">
        <div class="lp-stat-ico" style="background:#007bff"><i class="fas fa-truck"></i></div>
        <div class="lp-stat-num" style="color:#007bff">@Model.ActiveAssignments</div>
        <div class="lp-stat-lbl">Aktif Görev</div>
    </div>
    <div class="lp-stat">
        <div class="lp-stat-ico" style="background:#fd7e14"><i class="fas fa-users"></i></div>
        <div class="lp-stat-num" style="color:#fd7e14">@Model.ActiveVolunteers</div>
        <div class="lp-stat-lbl">Aktif Gönüllü</div>
    </div>
</div>

<div class="lp-map-row py-4">
    <h3 class="lp-section-title"><i class="fas fa-map-marked-alt"></i>Aktif Yardım Bölgeleri</h3>
    <p class="text-muted small mb-3">Anlık olarak yardım koordinasyonu yapılan bölgeler. Detay bilgisi için sisteme giriş yapınız.</p>
    <div id="lpMap"></div>
</div>

<div class="lp-how py-4">
    <h3 class="lp-section-title"><i class="fas fa-cogs"></i>Nasıl Çalışır?</h3>
    <div class="lp-steps">
        <div class="lp-step">
            <div class="badge-num">1</div>
            <i class="fas fa-edit fa-3x mb-3" style="color:#ffc107"></i>
            <div class="step-ttl">Talep Oluştur</div>
            <div class="step-sub">Afetzede konumunu işaretleyip ihtiyacını bildirir.</div>
        </div>
        <div class="lp-step">
            <div class="badge-num">2</div>
            <i class="fas fa-tasks fa-3x mb-3" style="color:#007bff"></i>
            <div class="step-ttl">Admin Koordine Eder</div>
            <div class="step-sub">Koordinatör talepleri onaylar ve gönüllü atar.</div>
        </div>
        <div class="lp-step">
            <div class="badge-num">3</div>
            <i class="fas fa-truck-loading fa-3x mb-3" style="color:#28a745"></i>
            <div class="step-ttl">Gönüllü Teslim Eder</div>
            <div class="step-sub">Gönüllü yardımı ulaştırır ve teslimatı onaylar.</div>
        </div>
    </div>
</div>

<div class="lp-ann py-4">
    <h3 class="lp-section-title"><i class="fas fa-bullhorn"></i>Son Duyurular</h3>
    @if (!Model.RecentAnnouncements.Any())
    {
        <p class="text-muted">Henüz duyuru yok.</p>
    }
    else
    {
        @foreach (var ann in Model.RecentAnnouncements)
        {
            <div class="lp-ann-card @(ann.IsUrgent ? "urgent" : "")">
                <div class="lp-ann-head">
                    <div>
                        @if (ann.IsUrgent) { <span class="lp-urgent-tag">ACİL</span> }
                        <span class="lp-ann-ttl">@ann.Title</span>
                    </div>
                    <span class="text-muted small"><i class="far fa-clock mr-1"></i>@ann.CreatedAt.ToString("dd.MM.yyyy")</span>
                </div>
                <div class="lp-ann-body">@ann.Content</div>
            </div>
        }
    }
</div>

<div class="lp-footer mt-5 p-4 bg-dark text-light rounded text-center">
    <div><strong>Afet Yönetim Sistemi</strong> · Muğla Sıtkı Koçman Üniversitesi · Final Projesi</div>
    <div class="mt-2"><a href="/Home/About" class="text-danger font-weight-bold">Hakkında</a></div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="~/js/site-maps.js"></script>
    <script>
        const lpPoints = @Html.Raw(JsonSerializer.Serialize(Model.MapPoints, jsonOpts));
        const lpMap = SiteMaps.initMap('lpMap', { center: [37.5, 37.0], zoom: 7, scrollWheelZoom: false });
        lpPoints.forEach(function (p) {
            L.marker([p.lat, p.lng], { icon: SiteMaps.urgencyIcon(p.urgency) }).addTo(lpMap);
        });
    </script>
}