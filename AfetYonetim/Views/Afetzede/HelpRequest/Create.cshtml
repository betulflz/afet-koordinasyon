@model AfetYonetim.Models.ViewModels.Afetzede.HelpRequestCreateViewModel

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <style>
        #pickerMap { height: 280px; border: 1px solid #ced4da; border-radius: 4px; position: relative; z-index: 1; }
        .coord-info { background: #e7f3ff; border: 1px solid #b3d7ff; border-radius: 4px;
                      padding: 6px 10px; font-size: 12px; color: #0050b3; margin-top: 6px; }
    </style>
}

<div class="row">
    <div class="col-md-9">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-plus-circle mr-2"></i>Yeni Yardım Talebi</h3>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Latitude" id="lat" />
                <input type="hidden" asp-for="Longitude" id="lng" />

                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label asp-for="Category"></label>
                            <select asp-for="Category" class="form-control"
                                    asp-items="Html.GetEnumSelectList<HelpCategory>()">
                                <option value="">-- Kategori Seçiniz --</option>
                            </select>
                            <span asp-validation-for="Category" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 form-group">
                            <label asp-for="Urgency"></label>
                            <select asp-for="Urgency" class="form-control"
                                    asp-items="Html.GetEnumSelectList<UrgencyLevel>()">
                            </select>
                            <span asp-validation-for="Urgency" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"
                                  placeholder="İhtiyacınızı detaylıca açıklayınız..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label asp-for="RegionId"></label>
                            <select asp-for="RegionId" id="regionSelect" class="form-control" asp-items="Model.RegionList">
                                <option value="">-- Bölge Seçiniz --</option>
                            </select>
                            <span asp-validation-for="RegionId" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 form-group">
                            <label asp-for="Location"></label>
                            <input asp-for="Location" class="form-control" placeholder="Örn: Antakya, Cumhuriyet Mh." />
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Harita Üzerinde Konum Seç (opsiyonel)</label>
                        <div id="pickerMap"></div>
                        <small class="form-text text-muted" id="pickerHint">
                            Bölge seçildikten sonra haritaya tıklayarak tam konumunuzu işaretleyebilirsiniz.
                            Tıklamazsanız bölgenin merkez koordinatı kullanılır.
                        </small>
                        <div id="coordInfo" class="coord-info" style="display:none;"></div>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane mr-1"></i> Talebi Gönder
                    </button>
                    <a href="/Afetzede/HelpRequest" class="btn btn-secondary ml-2">İptal</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="~/js/site-maps.js"></script>
    <script>
        const regionCoords = @Html.Raw(ViewBag.RegionCoords ?? "{}");

        const pickerMap = SiteMaps.initMap('pickerMap', { center: [39.0, 35.0], zoom: 6 });
        let selectedMarker = null;
        const coordInfo = document.getElementById('coordInfo');

        function setMarker(lat, lng) {
            if (selectedMarker) pickerMap.removeLayer(selectedMarker);
            selectedMarker = L.marker([lat, lng]).addTo(pickerMap);
            document.getElementById('lat').value = lat;
            document.getElementById('lng').value = lng;
            coordInfo.style.display = 'block';
            coordInfo.textContent = '📍 Seçilen konum: ' + lat.toFixed(4) + ', ' + lng.toFixed(4);
        }

        // Bölge dropdown değiştiğinde haritayı oraya uçur
        document.getElementById('regionSelect').addEventListener('change', function () {
            const id = this.value;
            if (id && regionCoords[id]) {
                const c = regionCoords[id];
                pickerMap.flyTo([c[0], c[1]], 11);
            }
        });

        // Haritaya tıkla → marker
        pickerMap.on('click', function (e) {
            setMarker(e.latlng.lat, e.latlng.lng);
        });
    </script>
}