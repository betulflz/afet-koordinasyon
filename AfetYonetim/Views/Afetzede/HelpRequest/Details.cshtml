@model AfetYonetim.Models.Entities.HelpRequest

@{
    string StatusBadge(AfetYonetim.Models.Enums.RequestStatus s) => s switch
    {
        AfetYonetim.Models.Enums.RequestStatus.Bekliyor => "badge-warning",
        AfetYonetim.Models.Enums.RequestStatus.Onaylandi => "badge-info",
        AfetYonetim.Models.Enums.RequestStatus.Atandi => "badge-primary",
        AfetYonetim.Models.Enums.RequestStatus.Yolda => "badge-secondary",
        AfetYonetim.Models.Enums.RequestStatus.TeslimEdildi => "badge-success",
        AfetYonetim.Models.Enums.RequestStatus.Reddedildi => "badge-danger",
        AfetYonetim.Models.Enums.RequestStatus.IptalEdildi => "badge-secondary",
        _ => "badge-dark"
    };
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-info-circle mr-2"></i>Talep Detayı</h3>
                <span class="badge @StatusBadge(Model.Status) float-right p-2">@Model.Status.GetDisplayName()</span>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Kategori</dt>
                    <dd class="col-sm-8">@Model.Category.GetDisplayName()</dd>

                    <dt class="col-sm-4">Aciliyet</dt>
                    <dd class="col-sm-8">@Model.Urgency.GetDisplayName()</dd>

                    <dt class="col-sm-4">Açıklama</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Konum (Adres)</dt>
                    <dd class="col-sm-8">@(Model.Location ?? "Belirtilmemiş")</dd>

                    <dt class="col-sm-4">Bölge</dt>
                    <dd class="col-sm-8">@Model.Region?.RegionName</dd>

                    <dt class="col-sm-4">Oluşturulma Tarihi</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
            <div class="card-footer">
                <a href="/Afetzede/HelpRequest" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left mr-1"></i> Listeye Dön
                </a>
                @if (Model.Status == AfetYonetim.Models.Enums.RequestStatus.Bekliyor || Model.Status == AfetYonetim.Models.Enums.RequestStatus.Onaylandi)
                {
                    <form action="/Afetzede/HelpRequest/Cancel/@Model.Id" method="post" class="d-inline ml-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger"
                                onclick="return confirm('Talebi iptal etmek istediğinizden emin misiniz?')">
                            <i class="fas fa-times mr-1"></i> Talebi İptal Et
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>