@model AfetYonetim.Models.ViewModels.Afetzede.HelpRequestListViewModel

@{
    string StatusBadge(AfetYonetim.Models.Enums.RequestStatus s) => s switch
    {
        AfetYonetim.Models.Enums.RequestStatus.Bekliyor => "badge-warning",
        AfetYonetim.Models.Enums.RequestStatus.Onaylandi => "badge-info",
        AfetYonetim.Models.Enums.RequestStatus.Atandi => "badge-primary",
        AfetYonetim.Models.Enums.RequestStatus.Yolda => "badge-secondary",
        AfetYonetim.Models.Enums.RequestStatus.TeslimEdildi => "badge-success",
        AfetYonetim.Models.Enums.RequestStatus.Reddedildi => "badge-danger",
        AfetYonetim.Models.Enums.RequestStatus.IptalEdildi => "badge-secondary",
        _ => "badge-dark"
    };
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title"><i class="fas fa-list-ul mr-2"></i>Taleplerim</h3>
        <a href="/Afetzede/HelpRequest/Create" class="btn btn-sm btn-primary">
            <i class="fas fa-plus mr-1"></i> Yeni Talep
        </a>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover table-striped">
            <thead class="thead-dark">
                <tr>
                    <th>Kategori</th>
                    <th>Aciliyet</th>
                    <th>Konum</th>
                    <th>Tarih</th>
                    <th>Durum</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">Henüz bir yardım talebi oluşturmadınız.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Category.GetDisplayName()</td>
                            <td>@item.Urgency.GetDisplayName()</td>
                            <td>@(item.Location ?? "Belirtilmemiş")</td>
                            <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            <td><span class="badge @StatusBadge(item.Status)">@item.Status.GetDisplayName()</span></td>
                            <td>
                                <a href="/Afetzede/HelpRequest/Details/@item.Id" class="btn btn-sm btn-info">
                                    <i class="fas fa-eye"></i> Detay
                                </a>
                                @if (item.Status == AfetYonetim.Models.Enums.RequestStatus.Bekliyor || item.Status == AfetYonetim.Models.Enums.RequestStatus.Onaylandi)
                                {
                                    <form action="/Afetzede/HelpRequest/Cancel/@item.Id" method="post" class="d-inline ml-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Talebi iptal etmek istediğinizden emin misiniz?')">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        @if (Model.TotalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center mt-3">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="/Afetzede/HelpRequest?page=@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>