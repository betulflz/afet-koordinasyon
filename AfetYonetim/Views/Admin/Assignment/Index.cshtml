@model AssignmentIndexViewModel

@{
    string AssignBadge(AssignmentStatus s) => s switch
    {
        AssignmentStatus.Atandi => "badge-primary",
        AssignmentStatus.Yolda => "badge-secondary",
        AssignmentStatus.TeslimEdildi => "badge-success",
        AssignmentStatus.Iptal => "badge-dark",
        _ => "badge-dark"
    };
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-tasks mr-2"></i>Görevlendirmeler</h3>
    </div>
    <div class="card-body">
        <form method="get" class="mb-3">
            <div class="row">
                <div class="col-md-3">
                    <select name="status" class="form-control">
                        <option value="">Tüm Durumlar</option>
                        @foreach (AssignmentStatus s in Enum.GetValues<AssignmentStatus>())
                        {
                            <option value="@s" selected="@(Model.Status == s)">@s.GetDisplayName()</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search mr-1"></i> Filtrele
                    </button>
                </div>
            </div>
        </form>

        <table class="table table-bordered table-hover table-striped">
            <thead class="thead-dark">
                <tr>
                    <th>Gönüllü</th>
                    <th>Talep Kategorisi</th>
                    <th>Talep Açıklaması</th>
                    <th>Durum</th>
                    <th>Atanma Tarihi</th>
                    <th>Teslim Tarihi</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted">Kayıt bulunamadı.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.VolunteerFullName</td>
                            <td>@item.RequestCategory.GetDisplayName()</td>
                            <td>@item.RequestDescription</td>
                            <td><span class="badge @AssignBadge(item.Status)">@item.Status.GetDisplayName()</span></td>
                            <td>@item.AssignedDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(item.DeliveryDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        @if (Model.TotalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center mt-3">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="/Admin/Assignment?page=@i&status=@Model.Status">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>