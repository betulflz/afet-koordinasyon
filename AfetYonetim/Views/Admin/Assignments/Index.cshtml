@{
    ViewData["Title"] = "Görevlendirmeler";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-tasks mr-2"></i>Görevlendirmeler</h3>
    </div>
    <div class="card-body">
        <p class="text-muted">Görevlendirme listesi Faz 2'de geliştirilecek.</p>
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Görev No</th>
                    <th>Talep</th>
                    <th>Gönüllü</th>
                    <th>Durum</th>
                    <th>Atanma Tarihi</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="6" class="text-center text-muted">Henüz görevlendirme bulunmuyor</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>