@model HelpRequestDetailViewModel

@{
    string StatusBadge(RequestStatus s) => s switch
    {
        RequestStatus.Bekliyor => "badge-warning",
        RequestStatus.Onaylandi => "badge-info",
        RequestStatus.Atandi => "badge-primary",
        RequestStatus.Yolda => "badge-secondary",
        RequestStatus.TeslimEdildi => "badge-success",
        RequestStatus.Reddedildi => "badge-danger",
        _ => "badge-dark"
    };

    string AssignBadge(AssignmentStatus s) => s switch
    {
        AssignmentStatus.Atandi => "badge-primary",
        AssignmentStatus.Yolda => "badge-warning",
        AssignmentStatus.TeslimEdildi => "badge-success",
        AssignmentStatus.Iptal => "badge-danger",
        _ => "badge-dark"
    };
}

<div class="row">
    <div class="col-md-8">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-info-circle mr-2"></i>Talep Bilgileri</h3>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Talep Eden</dt>
                    <dd class="col-sm-8">@Model.Request.User?.FullName</dd>
                    <dt class="col-sm-4">Kategori</dt>
                    <dd class="col-sm-8">@Model.Request.Category.GetDisplayName()</dd>
                    <dt class="col-sm-4">Açıklama</dt>
                    <dd class="col-sm-8">@Model.Request.Description</dd>
                    <dt class="col-sm-4">Durum</dt>
                    <dd class="col-sm-8"><span class="badge @StatusBadge(Model.Request.Status) p-2">@Model.Request.Status.GetDisplayName()</span></dd>
                </dl>
            </div>
        </div>

        @if (Model.Assignments.Any())
        {
            <div class="card">
                <div class="card-header"><h3 class="card-title">Görev Geçmişi</h3></div>
                <div class="card-body p-0">
                    <table class="table table-sm">
                        <thead><tr><th>Gönüllü</th><th>Durum</th><th>Tarih</th></tr></thead>
                        <tbody>
                            @foreach (var a in Model.Assignments) {
                                <tr><td>@a.Volunteer?.FullName</td><td><span class="badge @AssignBadge(a.Status)">@a.Status.GetDisplayName()</span></td><td>@a.AssignedDate.ToShortDateString()</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        <div class="card card-secondary">
            <div class="card-header"><h3 class="card-title">İşlemler</h3></div>
            <div class="card-body">
                @if (Model.Request.Status == RequestStatus.Bekliyor)
                {
                    <form asp-action="Approve" asp-route-id="@Model.Request.Id" method="post" class="mb-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success btn-block">Onayla</button>
                    </form>
                    <form asp-action="Reject" asp-route-id="@Model.Request.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-block">Reddet</button>
                    </form>
                }
                else if (Model.Request.Status == RequestStatus.Onaylandi)
                {
                    <button type="button" class="btn btn-primary btn-block" id="btnAssignModal">
                        <i class="fas fa-user-plus mr-1"></i> Gönüllü Ata
                    </button>
                }
                <hr />
                <a href="/Admin/HelpRequest" class="btn btn-outline-secondary btn-block">Listeye Dön</a>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="assignModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form asp-action="Assign" asp-route-id="@Model.Request.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Gönüllü Ata</h5>
                    <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Gönüllü Seç</label>
                        <select name="volunteerId" class="form-control" required>
                            <option value="">-- Gönüllü Seçiniz --</option>
                            @foreach (var v in Model.AvailableVolunteers) { <option value="@v.Value">@v.Text</option> }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Not</label>
                        <textarea name="notes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Atamayı Tamamla</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Butona basınca modalı manuel tetikle
            $('#btnAssignModal').click(function () {
                $('#assignModal').modal('show');
            });
        });
    </script>
}