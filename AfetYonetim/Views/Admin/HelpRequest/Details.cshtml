@model HelpRequestDetailViewModel

@{
    string StatusBadge(RequestStatus s) => s switch
    {
        RequestStatus.Bekliyor => "badge-warning",
        RequestStatus.Onaylandi => "badge-info",
        RequestStatus.Atandi => "badge-primary",
        RequestStatus.Yolda => "badge-secondary",
        RequestStatus.TeslimEdildi => "badge-success",
        RequestStatus.Reddedildi => "badge-danger",
        RequestStatus.IptalEdildi => "badge-secondary",
        _ => "badge-dark"
    };

    string AssignBadge(AssignmentStatus s) => s switch
    {
        AssignmentStatus.Atandi => "badge-primary",
        AssignmentStatus.Yolda => "badge-warning",
        AssignmentStatus.TeslimEdildi => "badge-success",
        AssignmentStatus.Iptal => "badge-danger",
        _ => "badge-dark"
    };

    // Lat/Long fallback: 0 ise Region'ın koordinatı kullanılır
    var lat = Model.Request.Latitude == 0 ? (Model.Request.Region?.Latitude ?? 39.0) : Model.Request.Latitude;
    var lng = Model.Request.Longitude == 0 ? (Model.Request.Region?.Longitude ?? 35.0) : Model.Request.Longitude;
    var urgency = Model.Request.Urgency.ToString();
    var locationLabel = Model.Request.Location ?? Model.Request.Region?.RegionName ?? "";
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <style> #detailMap { height: 160px; position: relative; z-index: 1; border-radius: 4px; } </style>
}

<div class="row">
    <div class="col-md-8">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-info-circle mr-2"></i>Talep Bilgileri</h3>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Talep Eden</dt>
                    <dd class="col-sm-8">@Model.Request.User?.FullName</dd>
                    <dt class="col-sm-4">Kategori</dt>
                    <dd class="col-sm-8">@Model.Request.Category.GetDisplayName()</dd>
                    <dt class="col-sm-4">Açıklama</dt>
                    <dd class="col-sm-8">@Model.Request.Description</dd>
                    <dt class="col-sm-4">Adres</dt>
                    <dd class="col-sm-8">@(Model.Request.Location ?? "-")</dd>
                    <dt class="col-sm-4">Bölge</dt>
                    <dd class="col-sm-8">@Model.Request.Region?.RegionName</dd>
                    <dt class="col-sm-4">Aciliyet</dt>
                    <dd class="col-sm-8">@Model.Request.Urgency.GetDisplayName()</dd>
                    <dt class="col-sm-4">Durum</dt>
                    <dd class="col-sm-8"><span class="badge @StatusBadge(Model.Request.Status) p-2">@Model.Request.Status.GetDisplayName()</span></dd>
                </dl>
            </div>
        </div>

        @if (Model.Assignments.Any())
        {
            <div class="card">
                <div class="card-header"><h3 class="card-title">Görev Geçmişi</h3></div>
                <div class="card-body p-0">
                    <table class="table table-sm">
                        <thead><tr><th>Gönüllü</th><th>Durum</th><th>Tarih</th></tr></thead>
                        <tbody>
                            @foreach (var a in Model.Assignments) {
                                <tr><td>@a.Volunteer?.FullName</td><td><span class="badge @AssignBadge(a.Status)">@a.Status.GetDisplayName()</span></td><td>@a.AssignedDate.ToShortDateString()</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        <!-- Faz 3: Mini Harita -->
        <div class="card mb-2 shadow-sm">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-map-marker-alt mr-2 text-danger"></i>Konum</h3>
                <span class="float-right text-muted small mt-1">@lat.ToString("F4"), @lng.ToString("F4")</span>
            </div>
            <div class="card-body p-0">
                 <div id="detailMap"></div>
            </div>
        </div>

        <div class="card card-secondary shadow-sm">
            <div class="card-header"><h3 class="card-title">İşlemler</h3></div>
            <div class="card-body">
                @if (Model.Request.Status == RequestStatus.Bekliyor)
                {
                    <form asp-action="Approve" asp-route-id="@Model.Request.Id" method="post" class="mb-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success btn-block"><i class="fas fa-check mr-2"></i>Onayla</button>
                    </form>
                    <form asp-action="Reject" asp-route-id="@Model.Request.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-block"><i class="fas fa-times mr-2"></i>Reddet</button>
                    </form>
                }
                else if (Model.Request.Status == RequestStatus.Onaylandi)
                {
                    <button type="button" class="btn btn-primary btn-block" id="btnAssignModal">
                        <i class="fas fa-user-plus mr-1"></i> Gönüllü Ata
                    </button>
                }
                <hr />
                <a href="/Admin/HelpRequest" class="btn btn-outline-secondary btn-block"><i class="fas fa-arrow-left mr-2"></i>Listeye Dön</a>
            </div>
        </div>
    </div>
</div>

<!-- Modal aynı kalıyor -->
<div class="modal fade" id="assignModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form asp-action="Assign" asp-route-id="@Model.Request.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Gönüllü Ata</h5>
                    <button type="button" class="close text-white" data-dismiss="modal"><span>&times;</span></button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label>Gönüllü Seç</label>
                        <select name="volunteerId" class="form-control" required>
                            <option value="">-- Gönüllü Seçiniz --</option>
                            @foreach (var v in Model.AvailableVolunteers) { <option value="@v.Value">@v.Text</option> }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Not</label>
                        <textarea name="notes" class="form-control" rows="2" placeholder="Gönüllüye iletilecek not..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">Atamayı Tamamla</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="~/js/site-maps.js"></script>
    <script>
        $(document).ready(function () {
            $('#btnAssignModal').click(function () { $('#assignModal').modal('show'); });
        });

        // C# virgül/nokta kültür sorununu çözmek için InvariantCulture kullandık.
        const detailLat = @lat.ToString(System.Globalization.CultureInfo.InvariantCulture);
        const detailLng = @lng.ToString(System.Globalization.CultureInfo.InvariantCulture);
        
        // Bizim büyücüyü çağırdık!
        const detailMap = SiteMaps.initMap('detailMap', { center: [detailLat, detailLng], zoom: 13, scrollWheelZoom: false });
        const detailPin = {
            lat: detailLat, lng: detailLng,
            title: '@Html.Raw(Model.Request.Category.GetDisplayName()) Talebi',
            status: '@Model.Request.Status.ToString()',
            urgency: '@urgency',
            subtitle: '@Html.Raw(locationLabel)',
            detailUrl: ''
        };
        SiteMaps.addPinToMap(detailMap, detailPin);
    </script>
}