@model HelpRequestDetailViewModel

@{
    string StatusBadge(RequestStatus s) => s switch
    {
        RequestStatus.Bekliyor => "badge-warning",
        RequestStatus.Onaylandi => "badge-info",
        RequestStatus.Atandi => "badge-primary",
        RequestStatus.Yolda => "badge-secondary",
        RequestStatus.TeslimEdildi => "badge-success",
        RequestStatus.Reddedildi => "badge-danger",
        _ => "badge-dark"
    };

    string AssignBadge(AssignmentStatus s) => s switch
    {
        AssignmentStatus.Atandi => "badge-primary",
        AssignmentStatus.Yolda => "badge-secondary",
        AssignmentStatus.TeslimEdildi => "badge-success",
        AssignmentStatus.Iptal => "badge-dark",
        _ => "badge-dark"
    };
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-info-circle mr-2"></i>Talep Bilgileri</h3>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Talep Eden</dt>
                    <dd class="col-sm-8">@Model.Request.User?.FullName</dd>

                    <dt class="col-sm-4">Telefon</dt>
                    <dd class="col-sm-8">@(Model.Request.User?.PhoneNumber ?? "Belirtilmemiş")</dd>

                    <dt class="col-sm-4">Kategori</dt>
                    <dd class="col-sm-8">@Model.Request.Category.GetDisplayName()</dd>

                    <dt class="col-sm-4">Açıklama</dt>
                    <dd class="col-sm-8">@Model.Request.Description</dd>

                    <dt class="col-sm-4">Konum</dt>
                    <dd class="col-sm-8">@(Model.Request.Location ?? "Belirtilmemiş")</dd>

                    <dt class="col-sm-4">Bölge</dt>
                    <dd class="col-sm-8">@Model.Request.Region?.RegionName</dd>

                    <dt class="col-sm-4">Aciliyet</dt>
                    <dd class="col-sm-8">@Model.Request.Urgency.GetDisplayName()</dd>

                    <dt class="col-sm-4">Durum</dt>
                    <dd class="col-sm-8">
                        <span class="badge @StatusBadge(Model.Request.Status) p-2">
                            @Model.Request.Status.GetDisplayName()
                        </span>
                    </dd>

                    <dt class="col-sm-4">Oluşturulma</dt>
                    <dd class="col-sm-8">@Model.Request.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>

        @if (Model.Assignments.Count > 0)
        {
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-history mr-2"></i>Görevlendirme Geçmişi</h3>
                </div>
                <div class="card-body p-0">
                    <table class="table table-bordered mb-0">
                        <thead>
                            <tr>
                                <th>Gönüllü</th>
                                <th>Durum</th>
                                <th>Atanma Tarihi</th>
                                <th>Teslim Tarihi</th>
                                <th>Not</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model.Assignments)
                            {
                                <tr>
                                    <td>@a.Volunteer?.FullName</td>
                                    <td><span class="badge @AssignBadge(a.Status)">@a.Status.GetDisplayName()</span></td>
                                    <td>@a.AssignedDate.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>@(a.DeliveryDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")</td>
                                    <td>@(a.Notes ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title"><i class="fas fa-cogs mr-2"></i>İşlemler</h3>
            </div>
            <div class="card-body">
                @if (Model.Request.Status == RequestStatus.Bekliyor)
                {
                    <form asp-action="Approve" asp-route-id="@Model.Request.Id" method="post" class="mb-2">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success btn-block">
                            <i class="fas fa-check mr-1"></i> Onayla
                        </button>
                    </form>
                    <form asp-action="Reject" asp-route-id="@Model.Request.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-block"
                                onclick="return confirm('Talebi reddetmek istediğinizden emin misiniz?')">
                            <i class="fas fa-times mr-1"></i> Reddet
                        </button>
                    </form>
                }
                else if (Model.Request.Status == RequestStatus.Onaylandi)
                {
                    <button type="button" class="btn btn-primary btn-block" data-toggle="modal" data-target="#assignModal">
                        <i class="fas fa-user-plus mr-1"></i> Gönüllü Ata
                    </button>
                }
                else
                {
                    <p class="text-muted text-center">Bu durumda yapılacak işlem yok.</p>
                }

                <hr />
                <a href="/Admin/HelpRequest" class="btn btn-outline-secondary btn-block">
                    <i class="fas fa-arrow-left mr-1"></i> Listeye Dön
                </a>
            </div>
        </div>
    </div>
</div>

@if (Model.Request.Status == RequestStatus.Onaylandi)
{
    <div class="modal fade" id="assignModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <form asp-action="Assign" asp-route-id="@Model.Request.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title">Gönüllü Ata</h5>
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="form-group">
                            <label for="volunteerId">Gönüllü Seçiniz</label>
                            <select name="volunteerId" id="volunteerId" class="form-control" required>
                                <option value="">-- Gönüllü Seçiniz --</option>
                                @foreach (var v in Model.AvailableVolunteers)
                                {
                                    <option value="@v.Value">@v.Text</option>
                                }
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="notes">Not (İsteğe Bağlı)</label>
                            <textarea name="notes" id="notes" class="form-control" rows="3"
                                      placeholder="Gönüllüye iletilecek not..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">İptal</button>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-user-check mr-1"></i> Ata
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}