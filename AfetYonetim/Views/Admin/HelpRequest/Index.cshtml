@{
    ViewData["Title"] = "Yardım Talepleri";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-hand-holding-heart mr-2"></i>Tüm Yardım Talepleri</h3>
    </div>
    <div class="card-body">
        <p class="text-muted">Talep listesi Faz 2'de geliştirilecek.</p>
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Talep No</th>
                    <th>Talep Eden</th>
                    <th>Kategori</th>
                    <th>Aciliyet</th>
                    <th>Durum</th>
                    <th>Tarih</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="7" class="text-center text-muted">Henüz talep bulunmuyor</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>