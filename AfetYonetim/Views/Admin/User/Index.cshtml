@model AfetYonetim.Models.ViewModels.Admin.UserIndexViewModel

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-users mr-2"></i>Kullanıcı Yönetimi</h3>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover table-striped">
                <thead class="thead-dark">
                    <tr>
                        <th>Ad Soyad</th>
                        <th>E-Posta</th>
                        <th>Bölge</th>
                        <th>Roller</th>
                        <th>Durum</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">Kullanıcı bulunamadı.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="align-middle">@item.FullName</td>
                                <td class="align-middle">@item.Email</td>
                                <td class="align-middle">@(item.RegionName ?? "-")</td>
                                <td class="align-middle">
                                    @foreach (var role in item.Roles)
                                    {
                                        <span class="badge badge-info mr-1">@role</span>
                                    }
                                </td>
                                <td class="align-middle">
                                    @if (item.IsActive)
                                    {
                                        <span class="badge badge-success p-2">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger p-2">Pasif</span>
                                    }
                                </td>
                                <td class="align-middle">
                                    <form action="/Admin/User/ToggleActive/@item.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-warning" title="Durumu Değiştir">
                                            <i class="fas fa-power-off"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav>
                <ul class="pagination justify-content-center mt-3">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="/Admin/User?page=@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    </div>
</div>