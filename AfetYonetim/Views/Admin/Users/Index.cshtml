@{
    ViewData["Title"] = "Kullanıcılar";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title"><i class="fas fa-users mr-2"></i>Kullanıcılar</h3>
    </div>
    <div class="card-body">
        <p class="text-muted">Kullanıcı listesi Faz 2'de geliştirilecek.</p>
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Ad Soyad</th>
                    <th>E-posta</th>
                    <th>Rol</th>
                    <th>Durum</th>
                    <th>Kayıt Tarihi</th>
                    <th>İşlem</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="6" class="text-center text-muted">Henüz kullanıcı bulunmuyor</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>